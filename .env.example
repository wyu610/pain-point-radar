# ─── Database (auto-injected by Vercel Marketplace → Neon) ──────────────
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# ─── Pain-point extraction LLM (priority order; first available wins) ───
# All four are optional — if all are missing, the heuristic fallback runs.
#
# 1. Anthropic Claude — best quality, ~$3-5/mo. Skip for free version.
# ANTHROPIC_API_KEY=sk-ant-...
#
# 2. Google Gemini — FREE 2.5 Flash, 1,500 req/day. Get key at https://aistudio.google.com
GEMINI_API_KEY=
#
# 3. OpenRouter free models (e.g. deepseek-chat:free, qwen-2.5:free).
#    Get key at https://openrouter.ai. Optional — only used if Gemini fails.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat:free

# ─── GitHub (optional, raises anonymous scrape rate from 60 → 5,000/hr) ──
GITHUB_TOKEN=

# ─── Vercel Cron header (set automatically when defined as project env) ──
CRON_SECRET=replace-me-32-chars

# ─── GitHub Actions autoresearch dispatch + callback (free for public repo)
WEBHOOK_SECRET=replace-me-32-chars
GH_DISPATCH_TOKEN=ghp_...
GH_WORKFLOW_OWNER=wyu610
GH_WORKFLOW_REPO=pain-point-radar
GH_WORKFLOW_FILE=autoresearch.yml

# ─── Public URL of this deployment ──────────────────────────────────────
APP_URL=https://your-app.vercel.app
RADAR_TZ=America/Denver
